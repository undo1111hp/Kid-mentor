<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <!-- Text chào ở trên -->
    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xin chào!"
        android:textSize="@dimen/text_greeting"
        android:textColor="#6BAF8A"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hôm nay, tớ có thể giúp gì cho cậu?"
        android:textSize="@dimen/text_sub_greeting"
        android:textStyle="bold"
        android:textColor="#2E7D52"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ① SÓNG ÂM — khai báo TRƯỚC ảnh để nằm phía sau -->
    <com.buivan.ptalk_child.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="0dp"
        android:layout_height="@dimen/waveform_height"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="120dp" />

    <!-- ② ẢNH NHÂN VẬT — khai báo SAU, tự động nổi lên trên sóng -->
    <ImageView
        android:id="@+id/ivCharacter"
        android:layout_width="@dimen/character_size"
        android:layout_height="@dimen/character_size"
        android:src="@drawable/char_idle1"
        android:scaleType="centerCrop"
        android:contentDescription="AI character"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="150dp"
        android:layout_marginBottom="120dp" />



    <!-- Nút hold to talk -->
<!--    <androidx.appcompat.widget.AppCompatButton-->
<!--        android:id="@+id/btnHoldToTalk"-->
<!--        android:layout_width="72dp"-->
<!--        android:layout_height="72dp"-->
<!--        android:text="🎙️"-->
<!--        android:textSize="28sp"-->
<!--        android:background="@drawable/bg_hold_button"-->
<!--        android:layout_marginBottom="60dp"-->
<!--        android:elevation="6dp"-->
<!--        app:layout_constraintBottom_toBottomOf="parent"-->
<!--        app:layout_constraintStart_toStartOf="parent"-->
<!--        app:layout_constraintEnd_toEndOf="parent" />-->
    <ImageButton
        android:id="@+id/btnHoldToTalk"
        android:layout_width="@dimen/btn_mic_size"
        android:layout_height="@dimen/btn_mic_size"
        android:src="@drawable/ic_mic_custom"
        android:background="@drawable/bg_hold_button"
        android:scaleType="centerInside"
        android:padding="18dp"
        android:layout_marginBottom="60dp"
        android:elevation="6dp"
        android:contentDescription="Ghi âm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



    <!-- Nút cancel -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCancel"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="⏹  Dừng lại"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_cancel_button"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone"
        android:elevation="4dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Text trạng thái -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chạm để ghi âm"
        android:textSize="@dimen/text_status"
        android:textColor="#8BAF9A"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Footer text -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Made by CTS PTIT"
        android:textSize="12sp"
        android:textColor="#8BAF9A"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Intro overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutIntro"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:elevation="100dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/ivIntroLogo"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:src="@drawable/ptit_logo"
            android:alpha="0"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

